{
  "name": "mywebpage",
  "version": "1.0.0",
  "description": "A dynamic and interactive personal webpage for Adil Nawaz, showcasing research in privacy-preserving machine learning.",
  "main": "index.html",
  "scripts": {
    "start": "live-server",
    "build": "npm run build-css && npm run build-js",
    "build-css": "postcss styles/site.css -o styles/dist/site.css",
    "build-js": "webpack --mode production"
  },
  "dependencies": {
    "live-server": "^1.2.1",
    "postcss": "^8.3.6",
    "webpack": "^5.64.4",
    "webpack-cli": "^4.9.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.3.7",
    "cssnano": "^5.0.6"
  },
  "keywords": [
    "personal",
    "webpage",
    "portfolio",
    "research",
    "machine learning"
  ],
  "author": "Adil Nawaz",
  "license": "MIT"
}